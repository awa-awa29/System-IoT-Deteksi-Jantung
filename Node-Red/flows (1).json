                "1893e53764082ff5"
            ]
        ]
    },
    {
        "id": "92745179f43763ec",
        "type": "function",
        "z": "d43fb467d47a24b9",
        "name": "function 2",
        "func": "// Ambil seluruh rentetan data yang sudah terkumpul di memori\nlet semuaData = flow.get(\"data_buffer\") || [];\n\n// Kirim seluruh rentetan data ini ke node CSV\nmsg.payload = semuaData;\n\n// KOSONGKAN memori kembali agar setelah di-save, antrean mulai dari nol lagi\nflow.set(\"data_buffer\", []);\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
