    {
        "id": "d5c4eedf0fe95a29",
        "type": "function",
        "z": "d43fb467d47a24b9",
        "name": "function 1",
        "func": "// Ambil list data yang sudah ada di memori, jika belum ada buat list kosong []\nlet listData = flow.get(\"data_buffer\") || [];\n\n// Masukkan data JSON terbaru dari MQTT ke dalam list\nlistData.push(msg.payload);\n\n// Simpan kembali list yang sudah bertambah ini ke memori\nflow.set(\"data_buffer\", listData);\n\n// Kita tidak perlu meneruskan msg ke output agar tidak membebani sistem\nreturn null;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 140,
        "y": 400,
        "wires": [
